# Teller credentials — sign up at https://teller.io and download mTLS certs.
# The Application ID identifies your app; the cert + key files authenticate
# every API request via mutual TLS. Place the .pem files under ./certs/
# (gitignored) and point the paths below at them.
TELLER_APPLICATION_ID=your_teller_application_id_here
TELLER_ENVIRONMENT=development
TELLER_CERT_PATH=./certs/teller-cert.pem
TELLER_KEY_PATH=./certs/teller-key.pem

# Anthropic API key — get this at https://console.anthropic.com/settings/keys
# Used for transaction categorization (Haiku) and the AI advisor chat (Opus).
ANTHROPIC_API_KEY=your_key_here

# Server port (optional)
PORT=3000
