# Plaid credentials — get these at https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here
PLAID_ENV=sandbox

# Comma-separated ISO country codes for the institution picker.
# Supported: US, CA, GB, IE, FR, ES, NL, DE, IT, PL, DK, NO, SE, EE, LT, LV, PT, BE
PLAID_COUNTRY_CODES=US

# Anthropic API key — get this at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here

# Server port (optional)
PORT=3000
